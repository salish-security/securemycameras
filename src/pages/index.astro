        .fear-item p { font-size: 14px; color: var(--text-secondary); line-height: 1.5; }

        .inside { padding: 60px 0; }
        .section-label {
            font-family: 'Space Mono', monospace;
            font-size: 12px;
            font-weight: 700;
            color: var(--danger);
            letter-spacing: 0.08em;
