        .proof { padding: 48px 0; }
        .proof-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            text-align: center;
        }
        .proof-item {
            background: var(--surface);
            border: 1px solid var(--border);
