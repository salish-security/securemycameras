            color: var(--text-secondary);
            max-width: 540px;
            margin: 0 auto 32px;
            line-height: 1.6;
        }

        .cta-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--danger);
            color: white;
            padding: 16px 36px;
