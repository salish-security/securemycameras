            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 36px;
            box-shadow: var(--shadow-sm);
        }
        .for-who-card h2 { font-size: 22px; font-weight: 700; margin-bottom: 20px; }
        .check-item { display: flex; gap: 12px; align-items: flex-start; padding: 10px 0; }
        .check-icon {
            flex-shrink: 0;
            width: 22px; height: 22px;
            background: var(--success-bg);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: var(--success);
            font-size: 12px;
            margin-top: 2px;
        }
        .check-item p { font-size: 15px; color: var(--text-secondary); }
        .check-item p strong { color: var(--text-primary); }

        .final-cta { padding: 60px 0; text-align: center; }
        .final-cta-card {
            background: var(--text-primary);
            color: white;
            border-radius: 16px;
            padding: 56px 36px;
            box-shadow: var(--shadow-xl);
        }
        .final-cta-card h2 {
            font-size: clamp(24px, 4vw, 32px);
            font-weight: 700;
            letter-spacing: -0.02em;
            margin-bottom: 12px;
        }
        .final-cta-card p {
