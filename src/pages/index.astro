        .final-cta-card .cta-note { color: #78716C; }
        .price-anchor { margin-bottom: 24px; }
        .price-anchor .old-price {
            font-size: 18px;
            color: #78716C;
            text-decoration: line-through;
            margin-right: 8px;
        }
        .price-anchor .new-price { font-size: 36px; font-weight: 700; color: white; }

        .faq { padding: 60px 0; }
        .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
        .faq-q {
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
        }
        .faq-q::after {
            content: '+';
            font-family: 'Space Mono', monospace;
            font-size: 20px;
            flex-shrink: 0;
            transition: transform 0.2s;
        }
        .faq-item.open .faq-q::after { content: '\2212'; }
        .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
        .faq-item.open .faq-a { max-height: 800px; }
        .faq-a p { padding-top: 12px; font-size: 15px; color: var(--text-secondary); line-height: 1.6; }

        footer { padding: 40px 0; text-align: center; border-top: 1px solid var(--border); }
        footer p { font-size: 13px; color: var(--text-muted); line-height: 1.8; }
        footer a { color: var(--text-secondary); }

        @media (max-width: 600px) {
            .proof-grid { grid-template-columns: 1fr; }
            .hero { padding: 48px 0 40px; }
            .fear-card, .for-who-card, .final-cta-card { padding: 24px; }
            .cta-btn { width: 100%; justify-content: center; font-size: 16px; padding: 16px 24px; }
            .nav-quiz-link { display: none; }
            .nav-cta { padding: 8px 14px; font-size: 13px; }
        }
    </style>
</head>
