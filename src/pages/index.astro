<!-- Paddle Checkout -->
<script is:inline src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
<script is:inline>
    // Initialize Paddle (SANDBOX MODE — for testing)
    Paddle.Environment.set('sandbox');
    Paddle.Initialize({
        token: 'test_4cc33c787bf309e13fcbb4dabec',
        eventCallback: function(event) {
            if (event.name === 'checkout.completed') {
                handleCheckoutComplete(event.data);
            }
        },
    });

    document.querySelectorAll('.paddle-buy').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            Paddle.Checkout.open({
                items: [{ priceId: 'pri_01km3xxxxj43c9q84yeyn3k642', quantity: 1 }],
            });
        });
    });

    // After successful checkout, get a signed download token and redirect to upsell
    async function handleCheckoutComplete(data) {
        var transactionId = data && data.transaction_id;
        var customerEmail = (data && data.customer && data.customer.email) || '';

        // Fire Meta Pixel Purchase event
        if (typeof fbq === 'function') {
            fbq('track', 'Purchase', { value: 29.00, currency: 'USD' });
        }

        if (!transactionId) {
            window.location.href = '/upsell' + (customerEmail ? '?email=' + encodeURIComponent(customerEmail) : '');
            return;
        }
        try {
            var res = await fetch('/api/create-download-token', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ transactionId: transactionId, fileType: 'guide' }),
            });
            var result = await res.json();
            if (result.ok && result.token && result.expires) {
                var url = '/upsell?token=' + encodeURIComponent(result.token) + '&expires=' + result.expires;
                if (customerEmail) url += '&email=' + encodeURIComponent(customerEmail);
                window.location.href = url;
            } else {
                window.location.href = '/upsell' + (customerEmail ? '?email=' + encodeURIComponent(customerEmail) : '');
            }
        } catch (err) {
            console.error('Token creation failed:', err);
            window.location.href = '/upsell';
        }
    }

    // FAQ Accordion
    document.querySelectorAll('.faq-q').forEach(function(q) {
        q.addEventListener('click', function() {
            var item = q.parentElement;
            var wasOpen = item.classList.contains('open');
            document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
            if (!wasOpen) item.classList.add('open');
        });
    });
</script>

