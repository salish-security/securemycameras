---
// Download recovery page — buyer enters purchase email, gets fresh download links
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recover Your Download | Secure My Cameras</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #FAFAF9;
            color: #1C1917;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }
        .card {
            background: white;
            border: 1px solid #E7E5E4;
            border-radius: 16px;
            padding: 48px 40px;
            max-width: 480px;
            width: 100%;
            text-align: center;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
        }
        .icon {
            width: 64px; height: 64px;
            background: #FEF3C7;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 24px;
            font-size: 28px;
        }
        h1 {
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 10px;
            letter-spacing: -0.02em;
        }
        .sub {
            font-size: 15px;
            color: #57534E;
            margin-bottom: 32px;
            line-height: 1.6;
        }
        label {
            display: block;
            text-align: left;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 6px;
            color: #1C1917;
        }
        input[type="email"] {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid #E7E5E4;
            border-radius: 8px;
            font-size: 16px;
            font-family: inherit;
            color: #1C1917;
            background: #FAFAF9;
            outline: none;
            transition: border-color 0.15s;
            margin-bottom: 16px;
        }
        input[type="email"]:focus { border-color: #DC2626; }
        button[type="submit"] {
            width: 100%;
            padding: 14px;
            background: #DC2626;
            color: white;
            font-size: 16px;
            font-weight: 700;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-family: inherit;
            transition: background 0.15s;
        }
        button[type="submit"]:hover { background: #B91C1C; }
        button[type="submit"]:disabled { background: #D4D4D4; cursor: not-allowed; }

        /* Result states */
        #result { display: none; margin-top: 24px; }
        .downloads { display: flex; flex-direction: column; gap: 12px; margin-top: 20px; }
        .download-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: #059669;
            color: white;
            padding: 14px 24px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 700;
            font-size: 16px;
            transition: all 0.2s;
        }
        .download-btn:hover { background: #047857; transform: translateY(-1px); }
        .download-btn.secondary { background: #2563EB; }
        .download-btn.secondary:hover { background: #1D4ED8; }
        .success-heading {
            font-size: 18px;
            font-weight: 700;
            color: #059669;
            margin-bottom: 6px;
        }
        .note { font-size: 13px; color: #A8A29E; margin-top: 16px; }
        .error-msg {
            font-size: 15px;
            color: #DC2626;
            font-weight: 500;
        }
        .not-found-msg { font-size: 15px; color: #57534E; }
        @media (max-width: 600px) {
            .card { padding: 32px 24px; }
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">&#128274;</div>
        <h1>Recover your download</h1>
        <p class="sub">Enter the email address you used at checkout and we'll generate a fresh download link.</p>

        <form id="recover-form">
            <label for="email">Purchase email address</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email">
            <button type="submit" id="submit-btn">Get my download link</button>
        </form>

        <div id="result">
            <!-- Populated by JS -->
        </div>

        <p class="note" style="margin-top:24px;">
            Need help? Email <a href="mailto:inquiry@salishsecurity.ai" style="color:#57534E;">inquiry@salishsecurity.ai</a>
        </p>
    </div>

    <script>
        var form = document.getElementById('recover-form');
        var result = document.getElementById('result');
        var submitBtn = document.getElementById('submit-btn');

        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            var email = document.getElementById('email').value.trim();
            if (!email) return;

            submitBtn.disabled = true;
            submitBtn.textContent = 'Looking up your order...';
            result.style.display = 'none';

            try {
                var resp = await fetch('/api/resend-download', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email })
                });
                var data = await resp.json();

                if (data.found && data.links) {
                    var html = '<p class="success-heading">&#10003; Order found — your links are ready</p>';
                    html += '<div class="downloads">';
                    if (data.links.guide) {
                        html += '<a href="' + data.links.guide + '" class="download-btn">&#128196; Download Secure Setup Guide</a>';
                    }
                    if (data.links.checklist) {
                        html += '<a href="' + data.links.checklist + '" class="download-btn secondary">&#128203; Download Network Security Checklist</a>';
                    }
                    html += '</div>';
                    html += '<p class="note">These links expire in 7 days. Bookmark this page to regenerate anytime.</p>';
                    result.innerHTML = html;
                } else {
                    result.innerHTML = '<p class="not-found-msg">No purchase found for that email. Make sure you\'re using the email you checked out with.<br><br>Still having trouble? Email <a href="mailto:inquiry@salishsecurity.ai" style="color:#DC2626;">inquiry@salishsecurity.ai</a></p>';
                }
            } catch (err) {
                result.innerHTML = '<p class="error-msg">Something went wrong. Please try again or contact support.</p>';
            }

            result.style.display = 'block';
            submitBtn.disabled = false;
            submitBtn.textContent = 'Get my download link';
        });
    </script>
</body>
</html>
