---
import CameraSecurityQuiz from "../components/CameraSecurityQuiz";
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Is Your Smart Camera Hackable? Free Security Quiz | securemycameras.com</title>
    <meta name="description" content="Answer 9 quick questions about your camera setup. Get an instant risk score and find out if your home security system is actually secure.">
    <!-- Meta Pixel — replace XXXXXXXXXXXXXXXX with your actual pixel ID -->
    <script is:inline>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', 'XXXXXXXXXXXXXXXX');
    fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=XXXXXXXXXXXXXXXX&ev=PageView&noscript=1" /></noscript>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #0C0F14; }
    </style>
</head>
<body>
    <CameraSecurityQuiz client:load />

<!-- Paddle Checkout (for direct purchase from quiz results) -->
<script is:inline src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
<script is:inline>
    // Initialize Paddle
    Paddle.Initialize({
        token: 'LIVE_PADDLE_CLIENT_TOKEN',
        eventCallback: function(event) {
            if (event.name === 'checkout.completed') {
                handleCheckoutComplete(event.data);
            }
        },
    });

    async function handleCheckoutComplete(data) {
        var transactionId = data && data.transaction_id;

        // Fire Meta Pixel Purchase event
        if (typeof fbq === 'function') {
            fbq('track', 'Purchase', { value: 29.00, currency: 'USD' });
        }

        if (!transactionId) {
            window.location.href = '/upsell';
            return;
        }
        try {
            var res = await fetch('/api/create-download-token', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ transactionId: transactionId, fileType: 'guide' }),
            });
            var result = await res.json();
            if (result.ok && result.token && result.expires) {
                window.location.href = '/upsell?token=' + encodeURIComponent(result.token) + '&expires=' + result.expires;
            } else {
                window.location.href = '/upsell';
            }
        } catch (err) {
            console.error('Token creation failed:', err);
            window.location.href = '/upsell';
        }
    }
</script>
</body>
</html>
