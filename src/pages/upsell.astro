---
// Post-purchase upsell page — shown after main guide checkout
// Flow: Paddle checkout success → /upsell?token=...&expires=... → /thank-you
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Guide Is On Its Way | Secure My Cameras</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #FAFAF9;
            --surface: #FFFFFF;
            --surface-alt: #F5F3F0;
            --text-primary: #1C1917;
            --text-secondary: #57534E;
            --text-muted: #A8A29E;
            --danger: #DC2626;
            --danger-bg: #FEF2F2;
            --success: #059669;
            --border: #E7E5E4;
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
            --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.04);
            --radius: 12px;
        }

        body {
            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 640px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .status-bar {
            text-align: center;
            margin-bottom: 32px;
        }

        .status-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #ECFDF5;
            font-size: 28px;
            margin-bottom: 12px;
        }

        .status-label {
            font-family: 'Space Mono', monospace;
            font-size: 12px;
            color: var(--success);
            letter-spacing: 0.06em;
            text-transform: uppercase;
            font-weight: 700;
        }

        .divider {
            width: 100%;
            height: 1px;
            background: var(--border);
            margin: 24px 0;
        }

        .upsell-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 40px 32px;
            box-shadow: var(--shadow-lg);
        }

        .wait-label {
            font-family: 'Space Mono', monospace;
            font-size: 11px;
            color: var(--danger);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 700;
            margin-bottom: 16px;
        }

        h1 {
            font-size: 28px;
            font-weight: 700;
            line-height: 1.3;
            margin-bottom: 12px;
        }

        .subtitle {
            font-size: 16px;
            color: var(--text-secondary);
            margin-bottom: 28px;
            line-height: 1.6;
        }

        .product-name {
            font-family: 'Space Mono', monospace;
            font-size: 13px;
            color: var(--text-primary);
            letter-spacing: 0.04em;
            text-transform: uppercase;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .product-price {
            font-size: 32px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 20px;
        }

        .product-desc {
            font-size: 15px;
            color: var(--text-secondary);
            margin-bottom: 24px;
            line-height: 1.6;
        }

        .benefits {
            list-style: none;
            margin-bottom: 32px;
        }

        .benefits li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 8px 0;
            font-size: 15px;
            color: var(--text-primary);
            line-height: 1.5;
        }

        .benefits li .check {
            color: var(--success);
            font-weight: 700;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .upsell-cta {
            display: block;
            width: 100%;
            padding: 16px 24px;
            background: var(--danger);
            color: white;
            border: none;
            border-radius: var(--radius);
            font-size: 17px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            text-align: center;
            box-shadow: 0 4px 14px rgba(220, 38, 38, 0.25);
            transition: background 0.15s ease;
        }

        .upsell-cta:hover {
            background: #B91C1C;
        }

        .skip-link {
            display: block;
            text-align: center;
            margin-top: 16px;
            color: var(--text-muted);
            font-size: 14px;
            text-decoration: none;
            cursor: pointer;
        }

        .skip-link:hover {
            color: var(--text-secondary);
        }

        footer {
            text-align: center;
            padding: 40px 20px;
            font-size: 13px;
            color: var(--text-muted);
        }

        footer a {
            color: var(--text-muted);
            text-decoration: underline;
        }
    </style>
</head>
<body>

<div class="container">
    <!-- Confirmation that guide purchase went through -->
    <div class="status-bar">
        <div class="status-icon">&#10003;</div>
        <div class="status-label">Purchase confirmed &mdash; your guide is ready</div>
    </div>

    <div class="upsell-card">
        <div class="wait-label">Wait &mdash; before you download</div>

        <h1>You just secured your cameras. Now what about the router they're running on?</h1>

        <p class="subtitle">
            The guide you just bought covers your cameras. But your cameras connect to a router &mdash;
            and if that router has default settings, you're still exposed.
        </p>

        <div class="divider"></div>

        <div class="product-name">Home Network Security Checklist</div>
        <div class="product-price"><s style="color: var(--text-muted); font-weight: 400; font-size: 22px;">$97</s> $47 <span style="font-size: 14px; font-weight: 400; color: var(--text-secondary);">&mdash; checkout-only price</span></div>

        <p class="product-desc">
            Goes deeper than the WiFi section in your guide. Covers your entire home network, not just cameras.
        </p>

        <ul class="benefits">
            <li><span class="check">&#10003;</span> Router-by-router hardening (15 brands covered, not just 6)</li>
            <li><span class="check">&#10003;</span> Device inventory spreadsheet &mdash; know exactly what's on your network</li>
            <li><span class="check">&#10003;</span> DNS-level ad/malware blocking setup (Pi-hole &amp; NextDNS walkthrough)</li>
            <li><span class="check">&#10003;</span> Full network audit checklist &mdash; run it quarterly in 15 minutes</li>
            <li><span class="check">&#10003;</span> Printer, smart TV, and IoT device lockdown steps</li>
        </ul>

        <button class="upsell-cta paddle-upsell-buy" type="button">
            Yes, Secure My Network Too &mdash; $47
        </button>

        <p style="font-size: 13px; color: var(--text-secondary); text-align: center; margin-top: 10px; margin-bottom: 4px;">
            Not useful? Full refund within 30 days. No questions.
        </p>

        <a class="skip-link" id="skip-upsell">No thanks, take me to my guide &rarr;</a>

        <p style="font-size: 11px; color: var(--text-muted); text-align: center; margin-top: 16px;">
            This offer is only available at checkout. After this page, the Network Checklist is $97.
        </p>
    </div>
</div>

<footer>
    <p>
        &copy; 2026 Salish Private Estates LLC. All rights reserved.<br>
        <a href="/legal/privacy">Privacy</a> &middot;
        <a href="/legal/terms">Terms</a>
    </p>
</footer>

<!-- Paddle Checkout (for upsell product) -->
<script is:inline src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
<script is:inline>
    // Initialize Paddle
    Paddle.Initialize({
        token: 'LIVE_PADDLE_CLIENT_TOKEN',
        eventCallback: function(event) {
            if (event.name === 'checkout.completed') {
                handleUpsellComplete(event.data);
            }
        },
    });

    // Carry guide download token through from query params
    var params = new URLSearchParams(window.location.search);
    var guideToken = params.get('token') || '';
    var guideExpires = params.get('expires') || '';

    // Hide confirmation banner if no valid token (direct navigation, not post-checkout)
    if (!guideToken || !guideExpires) {
        var statusBar = document.querySelector('.status-bar');
        if (statusBar) statusBar.style.display = 'none';
    }

    // Build the thank-you URL with guide token
    function buildThankYouUrl(includeUpsell) {
        var url = '/thank-you?token=' + encodeURIComponent(guideToken) + '&expires=' + encodeURIComponent(guideExpires);
        if (includeUpsell) url += '&upsell=true';
        return url;
    }

    // Upsell buy button
    document.querySelector('.paddle-upsell-buy').addEventListener('click', function(e) {
        e.preventDefault();
        Paddle.Checkout.open({
            // PLACEHOLDER — replace with actual upsell price ID from Paddle
            items: [{ priceId: 'LIVE_UPSELL_PRICE_ID', quantity: 1 }],
        });
    });

    // After upsell checkout completes — generate checklist-specific download token
    async function handleUpsellComplete(data) {
        var transactionId = data && data.transaction_id;
        if (transactionId) {
            try {
                var res = await fetch('/api/create-download-token', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ transactionId: transactionId, fileType: 'checklist' }),
                });
                var result = await res.json();
                if (result.ok && result.token && result.expires) {
                    var url = '/thank-you'
                        + '?token=' + encodeURIComponent(guideToken)
                        + '&expires=' + encodeURIComponent(guideExpires)
                        + '&upsell=true'
                        + '&utoken=' + encodeURIComponent(result.token)
                        + '&uexpires=' + encodeURIComponent(result.expires);
                    window.location.href = url;
                    return;
                }
            } catch (err) {
                console.error('Upsell token creation failed:', err);
            }
        }
        window.location.href = buildThankYouUrl(true);
    }

    // Skip upsell — go straight to guide download
    document.getElementById('skip-upsell').addEventListener('click', function(e) {
        e.preventDefault();
        window.location.href = buildThankYouUrl(false);
    });
</script>

</body>
</html>
