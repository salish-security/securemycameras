<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Privacy Policy | securemycameras.com</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #FAFAF9;
            color: #1C1917;
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
        }
        .container { max-width: 680px; margin: 0 auto; padding: 60px 24px 80px; }
        nav {
            background: white;
            border-bottom: 1px solid #E7E5E4;
            padding: 16px 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        nav .nav-inner {
            max-width: 680px;
            margin: 0 auto;
            padding: 0 24px;
        }
        nav a {
            font-family: 'Space Mono', monospace;
            font-weight: 700;
            font-size: 16px;
            color: #1C1917;
            text-decoration: none;
        }
        h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.02em; }
        .updated { font-size: 14px; color: #A8A29E; margin-bottom: 40px; }
        h2 { font-size: 20px; font-weight: 700; margin: 36px 0 12px; }
        p { font-size: 15px; color: #57534E; margin-bottom: 16px; }
